# Asurada Agent Configuration — Example
# Docs: https://github.com/miles990/asurada
#
# HOW TO USE:
#   1. Copy this file to asurada.yaml:
#        cp asurada.yaml.example asurada.yaml
#   2. Edit asurada.yaml to match your setup (agent name, persona, plugins, etc.)
#   3. asurada.yaml is git-ignored — your personal config stays local
#
# IMPORTANT: Asurada reads ALL configuration from this file — no environment
# variables. API keys, tokens, and secrets all go here. Keep asurada.yaml
# out of version control (.gitignore handles this automatically).
#
# perception.plugins — shell scripts defining what the agent can see
# skills — markdown files defining what the agent knows how to do
# loop — autonomous perception-driven cycle

agent:
  name: My Assistant
  persona: A helpful personal AI assistant that monitors your workspace.
  port: 3001
  # apiKey: your-api-key-here      # HTTP API auth (optional)

# Multi-agent mode — each agent gets its own memory namespace (memory/{name}/)
# agents:
#   my-agent:
#     persona: "Your agent's personality description"
# activeAgent: my-agent
loop:
  enabled: true
  interval: 5m
  # anthropicApiKey: sk-ant-...    # Required for anthropic-api runner
  # router:                     # Three-tier model routing (optional)
  #   enabled: true
  #   shadowMode: true           # Log decisions but always escalate (safe rollout)
  #   triageRunner:
  #     type: openai-compatible
  #     baseUrl: http://localhost:8000
  #     model: Qwen3.5-9B-4bit
  #   reflectRunner:
  #     type: claude-cli
  #     model: haiku
notification:
  providers:
    - type: console
    # - type: telegram
    #   options:
    #     botToken: "your-bot-token"
    #     chatId: "your-chat-id"
perception:
  categoryIntervals:
    workspace: 60000
    network: 120000
    heartbeat: 1800000
  plugins:
    - name: tasks
      script: ./plugins/task-tracker.sh
      category: workspace
    - name: git
      script: ./plugins/git-status.sh
      category: workspace
    # - name: chrome
    #   script: ./plugins/chrome-cdp.sh
    #   category: workspace
    #   interval: 120000
memory:
  topics: true
  search:
    enabled: true
    maxResults: 5
logging:
  categories:
    - agent
    - api
    - error
    - diag
    - behavior
lanes:
  maxConcurrent: 6
  maxTimeoutMs: 600000
  maxTurnsCap: 10
  outputTailChars: 5000
  typeDefaults:
    code:
      maxTurns: 5
      timeoutMs: 300000
    learn:
      maxTurns: 3
      timeoutMs: 300000
    research:
      maxTurns: 5
      timeoutMs: 480000
    create:
      maxTurns: 5
      timeoutMs: 480000
    review:
      maxTurns: 3
      timeoutMs: 180000
skills: []
cron:
  - schedule: "*/30 * * * *"
    task: Check pending tasks and execute if any
