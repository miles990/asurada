{
  "name": "asurada",
  "version": "0.1.0",
  "description": "Perception-driven personal AI agent framework — grows with you, not just for you",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "asurada": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/ui && cp src/ui/* dist/ui/",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "node --test dist/**/*.test.js"
  },
  "keywords": [
    "ai-agent",
    "personal-agent",
    "perception-driven",
    "autonomous",
    "self-evolving"
  ],
  "author": "Asurada Contributors",
  "homepage": "https://github.com/miles990/asurada#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miles990/asurada.git"
  },
  "bugs": {
    "url": "https://github.com/miles990/asurada/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "express": "^4.21.0",
    "node-cron": "^4.2.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.7.0"
  }
}
